import "@acton/build"
import "@acton/fmt"
import "@acton/fs"
import "@acton/io"
import "@acton/testing/expect"
import "../types/smart_account_blank.types"

const FIXTURE_BOC_PATH = "data/storm/smart_account_blank/testdata/SmartAccountBlank.boc"
const EXPECTED_BOC_MAGIC = 0xb5ee9c72
const EXPECTED_TRANSIENT_CODE_HASH =
    0xf1e54b12525577d408cb2a5a0ff8770c92f8a5be75497cf80247bfec4f66eaa9
const EXPECTED_SMART_ACCOUNT_CODE_HASH =
    0x91beb72642b69dd1217ddf6f488a9391b4d4b83d0131856b1157106091886f56
const EXPECTED_HIGHLOAD_TIMEOUT = 15552000
const EXPECTED_HOT_PUBLIC_KEY =
    87239587847142616048295798838787664456457434067972149231226244021718341634210
const EXPECTED_COLD_PUBLIC_KEY =
    77954538618246219238076980304107513279290426602386175610114018503125127500440
const EXPECTED_NATIVE_VAULT_ADDRESS = "0:E926764FF3D272C73DDEB836975C5521C025AD68E7919A25094E2DE3198805F1"
const EXPECTED_DEPLOY_OWNER_ADDRESS = "0:FBE207CDA150784FFD2A2489DCF96B75448BF9DD4B7060B3D30BBBAB770F700B"

fun hasBocMagic(bytes: slice): bool {
    if (bytes.remainingBitsCount() < 32) {
        return false;
    }
    return bytes.preloadUint(32) == EXPECTED_BOC_MAGIC;
}

fun expectInitializationData(initData: InitializationData): void {
    val keys = initData.keys.load();

    expect(initData.highloadTimeout).toEqual(EXPECTED_HIGHLOAD_TIMEOUT);
    expect(initData.version).toEqual(0);
    expect(initData.newCode.hash()).toEqual(EXPECTED_SMART_ACCOUNT_CODE_HASH);
    expect(keys.keysCount).toEqual(1);
    expect(keys.hotPublicKey).toEqual(EXPECTED_HOT_PUBLIC_KEY);
    expect(keys.coldPublicKey).toEqual(EXPECTED_COLD_PUBLIC_KEY);
    expect(keys.userPublicKeys).toHaveLength(1);
}

get fun `test smart account blank transient code boc fixture is real`() {
    val rawBoc = fs.readBytes(FIXTURE_BOC_PATH);
    expect(rawBoc).toBeNotNull();
    expect(hasBocMagic(rawBoc!)).toBeTrue();

    val code = build("SmartAccountBlank", FIXTURE_BOC_PATH);
    expect(code.hash()).toEqual(EXPECTED_TRANSIENT_CODE_HASH);
}

get fun `test smart account blank decodes real factory init body`() {
    val txHash = "CawnLiF85zosLyt0/I/PDUcJb8CymxIPMCUpfWJSAsc=";
    val txLt = "80059199000030";
    val body = parseCellFromBase64(
        "",
    );
    val decoded = StormInitSa.fromCell(body);
    expect(decoded.queryId).toEqual(1780004162);
    expectInitializationData(decoded.initData);

    println("STORM_SMART_ACCOUNT_BLANK_INIT_TX={} LT={}", txHash, txLt);
}

const SMART_ACCOUNT_BLANK_DEPOSIT_NOTIFY_WITH_DEPLOY_BODY_BOC = ""

get fun `test smart account blank decodes real deposit notify with deploy body`() {
    val txHash = "g99hGjcXTlJxI3eIdxmsdGfT99t4WLQLxd+RYXnfdw4=";
    val txLt = "78666674000008";
    val body = parseCellFromBase64(SMART_ACCOUNT_BLANK_DEPOSIT_NOTIFY_WITH_DEPLOY_BODY_BOC);
    val decoded = StormDepositNotifyWithDeploy.fromCell(body);

    var raw = body.beginParse();
    expect(raw.loadUint(32)).toEqual(0x18a092f7);
    expect(decoded.queryId).toEqual(1779450159);
    expect(decoded.vaultAddress).toEqual(address(EXPECTED_NATIVE_VAULT_ADDRESS));
    expect(decoded.amount).toEqual(100000000);
    expect(decoded.senderAddress).toEqual(address(EXPECTED_DEPLOY_OWNER_ADDRESS));
    expectInitializationData(decoded.initData);

    println("STORM_SMART_ACCOUNT_BLANK_DEPOSIT_NOTIFY_WITH_DEPLOY_TX={} LT={}", txHash, txLt);
}
